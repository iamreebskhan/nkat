################################################################################
# Local development environment template.
# Copy to .env and fill in real values. .env is gitignored.
################################################################################

# Postgres (matches docker-compose.yml defaults)
PGHOST=localhost
PGPORT=5432
PGDATABASE=billing_rules
PGUSER=app
PGPASSWORD=app_dev_only_change_in_prod
PGSSLMODE=disable

# Admin role for migrations + break-glass
PG_ADMIN_USER=admin
PG_ADMIN_PASSWORD=admin_dev_only_change_in_prod

# AWS (Phase 0 — placeholder)
AWS_REGION=us-east-1
AWS_PROFILE=billing-rules-dev

# AMA CPT license token (apply via royalties portal Phase 0)
AMA_LICENSE_TOKEN=

# CMS Coverage API license token (request via /v1/metadata/license-agreement)
CMS_COVERAGE_API_TOKEN=

# Bedrock / LLM (Phase 1+)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_SYNTHESIS=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_PARSER=anthropic.claude-3-5-haiku-20241022-v1:0
