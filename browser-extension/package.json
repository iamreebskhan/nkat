{
  "name": "billing-rules-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension that overlays pre-flight findings into any browser-based EHR.",
  "scripts": {
    "build": "node scripts/build.cjs",
    "test": "jest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@playwright/test": "~1.48.2",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "roots": ["<rootDir>/src"],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "jsdom",
    "setupFiles": ["<rootDir>/test/setup.ts"]
  }
}
