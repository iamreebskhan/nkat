{
  "manifest_version": 3,
  "name": "Billing Rules Pre-flight",
  "version": "0.1.0",
  "description": "Pre-flight CPT/HCPCS codes against payer × state rules from any browser-based EHR.",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "storage", "sidePanel", "scripting"],
  "host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open Billing Rules sidebar"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
