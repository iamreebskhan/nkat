# Copy to backend/.env and fill in values. NEVER commit the real .env.
# Production env vars come from your secret manager, not this file.

NODE_ENV=development
PORT=3000

# ----- Auth ------------------------------------------------------------------
# dev_header  → trusts X-Org-Id / X-User-Id headers (LOCAL DEV ONLY).
# jwt         → verifies inbound JWTs via JWKS or JWT_PUBLIC_KEY.
# AuthGuard refuses dev_header when NODE_ENV=production.
AUTH_MODE=dev_header

# ----- Postgres --------------------------------------------------------------
DATABASE_URL=postgres://admin:CHANGE_ME@localhost:5432/billing_rules
PGHOST=localhost
PGPORT=5432
PGDATABASE=billing_rules
PGUSER=admin
PGPASSWORD=CHANGE_ME
DB_APP_PASSWORD=CHANGE_ME

# Optional: BREAKGLASS Postgres role for the tenant-deletion executor.
# BREAKGLASS_DATABASE_URL=postgres://breakglass:CHANGE_ME@localhost:5432/billing_rules

# ----- Frontend / app URL ----------------------------------------------------
APP_BASE_URL=http://localhost:5173

# ----- AES-256 master key for tenant clearinghouse credentials ---------------
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=

# ----- AMA CPT license -------------------------------------------------------
# When unset, CPT short_descriptors are gated. HCPCS Level II is unaffected.
AMA_LICENSE_TOKEN=

# ----- CMS Coverage API ------------------------------------------------------
CMS_COVERAGE_TOKEN=

# ----- OIDC SSO (optional) ---------------------------------------------------
# Set ALL of these to enable /v1/auth/sso/start + /v1/auth/sso/callback.
# OIDC_AUTHORIZATION_URL=
# OIDC_TOKEN_URL=
# OIDC_JWKS_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://api.your-domain.com/v1/auth/sso/callback
# OIDC_SCOPE=openid profile email
# JWT_PUBLIC_KEY=          # PEM (SPKI) — pairs with SESSION_SIGNING_PRIVATE_KEY below
# JWT_ISSUER=https://api.your-domain.com
# JWT_AUDIENCE=billing-rules-frontend
# SSO_FRONTEND_REDIRECT=https://app.your-domain.com
# SESSION_SIGNING_PRIVATE_KEY=  # PEM (PKCS#8) — generate with the snippet in env.ts
# SESSION_TTL_SEC=3600

# ----- Stripe ---------------------------------------------------------------
STRIPE_API_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
# Rotation window — accepts both the new + previous secret simultaneously
# STRIPE_WEBHOOK_SIGNING_SECRET_PREVIOUS=

# ----- AWS SES ---------------------------------------------------------------
# SES_REGION=us-east-1
# EMAIL_FROM_ADDRESS=no-reply@your-domain.com
# SES_CONFIGURATION_SET=

# ----- Datadog (metrics + Error Tracking) ------------------------------------
# DD_AGENT_HOST=127.0.0.1
# DD_DOGSTATSD_PORT=8125

# ----- AWS Bedrock (synthesis) ----------------------------------------------
# Falls back to deterministic provider when unset.
# BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_SYNTHESIS=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_MODEL_PARSER=anthropic.claude-3-5-haiku-20241022-v1:0

# ----- Local file storage root (Final Rules drop folder) --------------------
# Default: ./var/uploads
# LOCAL_UPLOAD_ROOT=
