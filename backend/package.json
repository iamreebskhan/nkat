{
  "name": "billing-rules-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Medical billing rule lookup + reconciliation backend (Phase 1).",
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,scripts,test}/**/*.ts\" --max-warnings=0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "INTEGRATION=1 jest --config test/integration/jest-integration.config.cjs --runInBand",
    "test:smoke:bedrock": "BEDROCK_SMOKE=1 jest --config test/smoke/jest-smoke.config.cjs --runInBand",
    "cutover:dry-run": "ts-node scripts/cutover-dry-run.ts",
    "renewal:motion": "ts-node scripts/renewal-motion.ts",
    "billing:reconcile": "ts-node scripts/reconcile-billing.ts",
    "signup:expire": "ts-node scripts/expire-signup-attempts.ts",
    "billing:emails": "ts-node scripts/send-billing-emails.ts",
    "email:retry": "ts-node scripts/retry-failed-emails.ts",
    "cleanup:expired": "ts-node scripts/cleanup-expired-records.ts",
    "db:migrate": "ts-node scripts/migrate.ts",
    "db:migrate:dry": "ts-node scripts/migrate.ts --dry-run",
    "db:migrate:verify": "ts-node scripts/migrate.ts --verify",
    "db:execute-deletions": "ts-node scripts/execute-tenant-deletions.ts",
    "ingest:ncci": "ts-node scripts/ingest-ncci-quarterly.ts",
    "ingest:drg": "ts-node scripts/ingest-ms-drg.ts",
    "extract:final-rules": "ts-node scripts/extract-final-rules.ts",
    "expire:dsar": "ts-node scripts/expire-dsar.ts",
    "render:status": "ts-node scripts/render-status-page.ts",
    "cache:invalidate": "ts-node scripts/invalidate-cache.ts",
    "webhooks:deliver": "ts-node scripts/deliver-webhooks.ts",
    "ses:simulator": "ts-node scripts/ses-feedback-simulator.ts",
    "stage:health": "ts-node scripts/stage-health-check.ts",
    "openapi:export": "ts-node scripts/export-openapi.ts",
    "ingest:palliative": "ts-node scripts/ingest-palliative.ts",
    "ingest:era835": "ts-node scripts/ingest-era835-batch.ts",
    "reverification:mark-overdue": "ts-node scripts/reverification-mark-overdue.ts",
    "ingest:hcc": "ts-node scripts/ingest-hcc-v28.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1043.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "kysely": "^0.27.4",
    "nestjs-pino": "^4.1.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      ".module.ts$",
      "main.ts$",
      ".dto.ts$",
      "/types.ts$"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/test/setup-env.ts"
    ]
  }
}
